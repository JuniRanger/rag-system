# Ollama
OLLAMA_BASE_URL=puerto
OLLAMA_MODEL=modelo
# Tiempo que el modelo permanece en memoria (servidor: OLLAMA_KEEP_ALIVE=24h ollama serve)
OLLAMA_KEEP_ALIVE=timestamp

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=puerto
QDRANT_COLLECTION_NAME=nombre_coleccion

# Embeddings
EMBEDDING_MODEL_NAME=modelo_embeddings
EMBEDDING_DIMENSION=dimensiones

# Chunking
CHUNK_SIZE=tamaño_chunk
CHUNK_OVERLAP=solapamiento

# Retrieval
TOP_K=cantidad_hits

# App
DEBUG=boolean