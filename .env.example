# Ollama (en el host; con Docker usar host.docker.internal en compose)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_KEEP_ALIVE=24h
# Modelo de embeddings en Ollama (dimension debe igualar EMBEDDING_DIMENSION)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# ollama | local — usa local si tu coleccion fue creada con sentence-transformers (384)
INCREMENTAL_EMBEDDING_BACKEND=local

# Supabase webhook (ingesta incremental)
SUPABASE_WEBHOOK_SECRET=
SUPABASE_RECORD_ID_FIELD=id
SUPABASE_RECORD_TEXT_FIELD=content
SUPABASE_RECORD_TEXT_FIELD_ALT=text
# Vacio = todas las tablas; ejemplo: documents,articles
SUPABASE_WEBHOOK_ALLOWED_TABLES=

# Qdrant (local: localhost | Docker Compose: qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K=10

# App
DEBUG=False
