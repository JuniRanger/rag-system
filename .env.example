# Ollama (en el host; con Docker usar host.docker.internal en compose)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_KEEP_ALIVE=24h

# Qdrant (local: localhost | Docker Compose: qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K=10

# App
DEBUG=False
PROVIDER_TYPE=LOCAL

# Supabase (ingesta desde tabla + webhook)
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
SUPABASE_TABLE=documentos_tecnicos
SUPABASE_ID_COLUMN=id
SUPABASE_CURSOR_COLUMN=id
# Columnas de texto a indexar (solo estas se ingestan), separadas por coma
SUPABASE_TEXT_COLUMNS=vehiculo_marca,vehiculo_modelo,categoria_problema,problema,diagnostico,solucion
# Secreto que Supabase enviará en el header X-Webhook-Secret
SUPABASE_WEBHOOK_SECRET=un_secreto_largo_y_aleatorio
# Opcional: proteger POST /api/v1/sync con header X-Sync-Secret
SUPABASE_SYNC_SECRET=
